---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
---

<article class:list={["project-card", featured ? "project-card--featured" : "project-card--compact", project.media?.src ? "" : "project-card--no-media"]}>
  {
    project.media?.src ? (
      <div class:list={["media-slot", project.media.type === "youtube" ? "media-slot--video" : ""]}>
        {project.media.type === "youtube" ? (
          <iframe
            src={project.media.src}
            title={project.media.title ?? project.media.alt}
            loading={featured ? "eager" : "lazy"}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          />
        ) : (
          <img
            src={project.media.src}
            alt={project.media.alt}
            loading={featured ? "eager" : "lazy"}
          />
        )}
      </div>
    ) : null
  }
  <div class="project-card__meta">
    <span>{project.category}</span>
  </div>
  <h3>{project.title}</h3>
  {project.context ? <p class="card-context">{project.context}</p> : null}
  <p>{project.summary}</p>
  <dl class="evidence-grid">
    <div>
      <dt>Role</dt>
      <dd>{project.role}</dd>
    </div>
    <div>
      <dt>Outcome</dt>
      <dd>{project.outcome}</dd>
    </div>
  </dl>
  <ul class="check-list">
    {project.details.slice(0, featured ? 3 : 2).map((detail) => <li>{detail}</li>)}
  </ul>
  <div class="tag-row" aria-label={`Technologies used for ${project.title}`}>
    {project.stack.map((item) => <span>{item}</span>)}
  </div>
  {
    project.links?.length ? (
      <div class="link-row">
        {project.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    ) : null
  }
</article>
