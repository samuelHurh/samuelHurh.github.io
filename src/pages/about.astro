---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, skills } from "../data/site";
---

<BaseLayout title="About" description="About Samuel Hurh, XR and spatial computing software engineer.">
  <section class="section">
    <div class="split">
      <div>
        <p class="eyebrow">About</p>
        <h1>CS BS/MS graduate focused on XR, perception, and real-time interactive systems.</h1>
        <p class="lede">
          I studied Computer Science at the University of Illinois
          Urbana-Champaign and focus on spatial computing software: tracking,
          sensing, interaction, rendering, and networking.
        </p>
        <p>
          My work is strongest where physical-world data and real-time interfaces
          meet: Unity/OpenXR prototypes, Magic Leap 2 and Meta Quest development,
          spatial interaction research, networked VR, and graphics/rendering
          experiments.
        </p>
        <p>
          I am targeting XR, spatial computing, perception, simulation, and
          real-time interactive software roles.
        </p>
        <div class="cta-row">
          <a class="button" href="/resume/">Resume</a>
          <a class="button secondary" href={site.links.linkedin}>LinkedIn</a>
        </div>
      </div>
      <div>
        <img class="portrait" src="/profile.jpg" alt="Samuel Hurh" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section compact">
    <p class="eyebrow">Technical interests</p>
    <div class="grid three">
      <article class="info-card">
        <h3>XR and spatial interfaces</h3>
        <p>
          OpenXR, Unity, Magic Leap 2, Meta Quest, interaction systems, and
          real-time interface behavior for AR/VR applications.
        </p>
      </article>
      <article class="info-card">
        <h3>Perception and alignment</h3>
        <p>
          Depth sensing, pose estimation, point clouds, marker alignment, ICP,
          calibration workflows, and visualization of sensed state.
        </p>
      </article>
      <article class="info-card">
        <h3>Rendering and graphics</h3>
        <p>
          Shader-level rendering tradeoffs, WebGL, ray tracing, rasterization,
          terrain generation, and performance-aware visual systems.
        </p>
      </article>
    </div>
  </section>

  <section class="section compact">
    <p class="eyebrow">Skills</p>
    <h2>Tools I can discuss concretely.</h2>
    <div class="tag-row">
      {skills.map((skill) => <span>{skill}</span>)}
    </div>
  </section>
</BaseLayout>
