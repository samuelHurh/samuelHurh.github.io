---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, skills } from "../data/site";
---

<BaseLayout title="About" description="About Samuel Hurh, XR and spatial computing software engineer.">
  <section class="section">
    <div class="split about-hero">
      <div>
        <p class="eyebrow">About</p>
        <h1>UIUC CS BS + MCS graduate focused on XR, wearable AI, and real-time interactive systems.</h1>
        <p class="lede">
          I'm a UIUC CS BS + MCS graduate focused on AR/VR, wearable AI, and
          real-time 3D software. My work sits where software has to line up with
          the physical world: cameras, depth sensing, pose alignment, spatial
          interaction, rendering, and usable interfaces.
        </p>
        <p>
          Recently, I've been building a Google Glass AI assistant prototype
          while continuing work across Unity/OpenXR, Magic Leap 2, Meta Quest,
          and computer-vision-driven AR workflows.
        </p>
        <div class="cta-row">
          <a class="button" href="/resume/">Resume</a>
          <a class="button secondary" href={site.links.linkedin}>LinkedIn</a>
        </div>
      </div>
      <div class="portrait-card">
        <img class="portrait" src="/profile.jpg" alt="Samuel Hurh" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section compact">
    <p class="eyebrow">Technical Focus</p>
    <div class="grid three">
      <article class="info-card">
        <h3>Wearable AI & AR/VR Interfaces</h3>
        <p>
          Google Glass EE2, Android/Kotlin, OpenXR, Unity, Magic Leap 2, Meta Quest,
          hands-free interaction, and real-time interface behavior.
        </p>
      </article>
      <article class="info-card">
        <h3>Perception & Spatial Alignment</h3>
        <p>
          Depth sensing, pose estimation, point clouds, marker alignment, ICP,
          calibration workflows, and visualization of sensed state.
        </p>
      </article>
      <article class="info-card">
        <h3>Rendering & Interactive 3D</h3>
        <p>
          WebGL, shaders, ray tracing, rasterization, terrain generation, Unity
          scenes, and performance-aware visual systems.
        </p>
      </article>
    </div>
  </section>

  <section class="section compact">
    <p class="eyebrow">Tools & Systems</p>
    <div class="tag-row">
      {skills.map((skill) => <span>{skill}</span>)}
    </div>
  </section>
</BaseLayout>
