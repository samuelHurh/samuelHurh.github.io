---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, skills } from "../data/site";
---

<BaseLayout title="About" description="About Samuel Hurh, XR and spatial computing software engineer.">
  <section class="section">
    <div class="split about-hero">
      <div>
        <p class="eyebrow">About</p>
        <h1>Building real-time interactive systems for the physical world.</h1>
        <p class="lede">
          I’m a UIUC CS BS + MCS graduate focused on software that connects digital systems with real-world context. My work spans XR, wearable AI, computer vision, and spatial interfaces, with recent projects on Google Glass, Unity/OpenXR, Magic Leap 2, Meta Quest, and camera-driven AR workflows.
        </p>
        <p>
          Recently, I've been building my own capable AI Glasses wearable with the Google Glass Enterprise Edition as a hardware base for real-time voice and camera interface.
        </p>
        <div class="cta-row">
          <a class="button" href="/resume/">Resume</a>
          <a class="button secondary" href={site.links.linkedin}>LinkedIn</a>
        </div>
      </div>
      <div class="portrait-card">
        <img class="portrait" src="/profile.jpg" alt="Samuel Hurh" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section compact">
    <p class="eyebrow">Technical Focus</p>
    <div class="grid three">
      <article class="info-card">
        <h3>Wearable AI & AR/VR Interfaces</h3>
        <p>
          Google Glass EE2, Android/Kotlin development, OpenXR, Unity, Magic Leap 2, Meta Quest,
          and real-time interface behavior.
        </p>
      </article>
      <article class="info-card">
        <h3>Perception & Spatial Alignment</h3>
        <p>
          Depth sensing, pose estimation, point clouds, marker alignment, ICP,
          calibration workflows, and visualization of digital information in physical space.
        </p>
      </article>
      <article class="info-card">
        <h3>Rendering & Interactive 3D</h3>
        <p>
          WebGL, shaders, ray tracing, rasterization, Unity
          development in professional and research settings, and performance-aware visual systems.
        </p>
      </article>
    </div>
  </section>

  
</BaseLayout>
