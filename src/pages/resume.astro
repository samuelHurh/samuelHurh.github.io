---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="Resume" description="Resume for Samuel Hurh.">
  <section class="section compact">
    <p class="eyebrow">Resume</p>
    <h1>Resume</h1>
    <p class="lede">
      A direct PDF version is embedded below and available as a separate download.
    </p>
    <div class="cta-row">
      <a class="button" href={site.links.resume}>Open PDF</a>
      <a class="button secondary" href={site.links.resume} download>Download PDF</a>
    </div>
  </section>
  <section class="section compact">
    <iframe class="resume-frame" src={site.links.resume} title="Samuel Hurh resume PDF"></iframe>
  </section>
</BaseLayout>
