---
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projectSections } from "../data/projects";
---

<BaseLayout title="Projects" description="Selected public projects by Samuel Hurh.">
  <section class="section">
    <p class="eyebrow">Projects</p>
    <h1>Selected Public Projects</h1>
    <p class="lede">
      Public demos and prototypes across wearable AI, AR/VR, real-time
      interaction, graphics, and spatial systems.
    </p>
  </section>

  {
    projectSections.map((section) => (
      <section class="section compact">
        <div class="section-heading">
          <div>
            <p class="eyebrow">{section.title}</p>
          </div>
        </div>
        <div class:list={["grid", section.title === "Featured Work" ? "featured-grid" : "two", "secondary-project-grid"]}>
          {section.projects.map((project) => (
            <ProjectCard project={project} featured={section.title === "Featured Work"} />
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>
