---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const routes = [
  {
    title: "About",
    href: "/about/",
    summary: "Background, technical direction, and current XR/spatial computing focus.",
  },
  {
    title: "Projects",
    href: "/projects/",
    summary: "Public work in wearable AI, XR, computer vision, graphics, and interactive systems.",
  },
  {
    title: "Work",
    href: "/work/",
    summary: "Professional and research contexts, kept separate from public project breakdowns.",
  },
];
---

<BaseLayout title="Home" description={site.tagline}>
  <section class="hero">
    <div>
      <p class="eyebrow">Software Engineer / AR/VR / Wearable AI / Real-Time 3D</p>
      <h1>{site.name}</h1>
      <p class="lede">{site.tagline}</p>
      <p>
        CS BS + MCS graduate from UIUC with hands-on work across Google Glass,
        Unity/OpenXR, Magic Leap 2, Meta Quest, computer vision, and real-time
        interactive prototypes.
      </p>
      <div class="cta-row">
        <a class="button" href="/resume/">View Resume</a>
        <a class="button secondary" href="/projects/">See Projects</a>
        <a class="button secondary" href={`mailto:${site.email}`}>Email Me</a>
      </div>
      <div class="hero-links" aria-label="Primary profile links">
        <a href={site.links.github}>GitHub</a>
        <a href={site.links.linkedin}>LinkedIn</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </div>
    </div>
    <aside class="hero-panel spatial-visual" aria-label="Spatial computing visual motif">
      <img
        class="hero-visual-image"
        src="/media/awe_splash.jpeg"
        alt="Samuel Hurh at AWE with smart glasses demo equipment"
        loading="eager"
        onerror="this.style.display = 'none'"
      />
      <div class="visual-label">
        <strong>Current work</strong>
        <span>Smart-glasses AI, industrial AR/CV, and real-time spatial systems.</span>
      </div>
    </aside>
  </section>

  <section class="section compact">
    <p class="eyebrow">Start here</p>
    <div class="route-grid">
      {
        routes.map((route) => (
          <a class="route-card" href={route.href}>
            <span>{route.title}</span>
            <p>{route.summary}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
